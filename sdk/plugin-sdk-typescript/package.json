{
  "name": "@agent-world/plugin-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for building Agent World skill plugins",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "agent-world",
    "plugin",
    "sdk",
    "wasm",
    "simulation"
  ],
  "author": "Agent World Team",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
