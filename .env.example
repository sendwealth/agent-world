# ── Agent World Docker Compose Configuration ────────────────
# Copy this file to .env and adjust values as needed.

# ── World Engine (Rust) ─────────────────────────────────────
HOST=0.0.0.0
PORT=3000
RUST_LOG=info

# ── Agent Runtime (Python) ──────────────────────────────────
WORLD_ENGINE_URL=http://world-engine:3000
AGENT_COUNT=2
LLM_PROVIDER=ollama
LLM_MODEL=llama3
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Dashboard (Next.js) ────────────────────────────────────
DASHBOARD_PORT=3001
