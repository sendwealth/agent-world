# ── Agent World Docker Compose Configuration ────────────────
# Copy this file to .env and adjust values as needed.

# ── World Engine (Rust) ─────────────────────────────────────
HOST=0.0.0.0
PORT=3000
RUST_LOG=info

# ── Agent Runtime (Python) ──────────────────────────────────
WORLD_ENGINE_URL=http://world-engine:3000
AGENT_COUNT=2

# ── LLM Configuration ───────────────────────────────────────
# Default: Ollama (zero-cost, local). Requires Ollama running with a model pulled.
# Alternatives: openai, anthropic, zhipu (智谱GLM-5)
LLM_PROVIDER=ollama
LLM_MODEL=llama3

# --- Ollama (default, zero-cost) ---
# Requires Ollama installed and running (https://ollama.com)
# Pull a model: ollama pull llama3
# Requires ~8GB RAM for llama3
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Zhipu GLM-5 (cheap pay-per-use) ---
# Uncomment and fill in to use 智谱GLM-5 API
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-5
# ZHIPU_API_KEY=your_zhipu_api_key_here
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- OpenAI ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.openai.com/v1

# --- Anthropic ---
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3.5-haiku
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Dashboard (Next.js) ────────────────────────────────────
DASHBOARD_PORT=3001
