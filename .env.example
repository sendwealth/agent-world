# ── Agent World Environment Variables ────────────────────────
# Copy this file to .env and adjust values as needed.
# All values have sensible defaults — only override what you need.

# ── CORS (Required in production) ──────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Default (when unset): http://localhost:3001, http://localhost:8080
# Production example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# ── World Engine (Rust) ─────────────────────────────────────
ENGINE_PORT=8080          # REST API port
GRPC_PORT=50051           # gRPC A2A protocol port
RUST_LOG=info             # Logging level: trace|debug|info|warn|error

# ── Authentication (REQUIRED) ──────────────────────────────
# JWT_SECRET must be set to a strong random string.
# Generate one: openssl rand -base64 48
JWT_SECRET=change-me-to-a-strong-random-string

# ── Agent Runtime (Python) ──────────────────────────────────
WORLD_ENGINE_URL=http://world-engine:8080
# Number of agent instances defined in docker-compose.yml (agent-01 through agent-10).
# Adjust this value to document how many agents you intend to run.
# Agents load per-instance config from config/agents/*.toml
AGENT_COUNT=10

# ── LLM Configuration ───────────────────────────────────────
# These variables control which LLM provider each agent runtime uses.
# The docker-compose.yml defaults are: LLM_PROVIDER=zhipu, LLM_MODEL=glm-4-flash.
# Override here or via CLI to switch providers. Set LLM_API_KEY / LLM_BASE_URL
# when using openai or anthropic providers.

LLM_PROVIDER=zhipu
LLM_MODEL=glm-4-flash
LLM_API_KEY=${ZHIPU_API_KEY:-}        # API key forwarded to the provider
LLM_BASE_URL=${ZHIPU_BASE_URL:-}      # Base URL forwarded to the provider

# --- Zhipu GLM (default, cheap pay-per-use) ---
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- Ollama (local, zero-cost) ---
# Requires Ollama installed and running (https://ollama.com)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- OpenAI ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.openai.com/v1

# --- Anthropic ---
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3.5-haiku
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Dashboard (Next.js) ────────────────────────────────────
DASHBOARD_PORT=3001       # Host port mapped to dashboard container

# ── Ollama (optional, use --profile local-llm) ─────────────
OLLAMA_PORT=11434         # Host port for Ollama service

# ── Grafana (optional, use --profile observability) ──────────
GRAFANA_PORT=3002          # Host port for Grafana dashboard
# IMPORTANT: Change the admin password before exposing Grafana.
# Generate a strong one: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=admin
# Disable anonymous access by default. Set to true only for local-only dev.
GF_AUTH_ANONYMOUS_ENABLED=false
