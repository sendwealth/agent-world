# ── Agent World Environment Variables ────────────────────────
# Copy this file to .env and adjust values as needed.
# All values have sensible defaults — only override what you need.

# ── World Engine (Rust) ─────────────────────────────────────
ENGINE_PORT=8080          # REST API port
GRPC_PORT=50051           # gRPC A2A protocol port
RUST_LOG=info             # Logging level: trace|debug|info|warn|error

# ── Agent Runtime (Python) ──────────────────────────────────
# Individual agents load their config from config/agents/*.toml
# LLM settings here apply as defaults; agent configs can override.
LLM_PROVIDER=ollama       # LLM provider: openai|anthropic|ollama
LLM_MODEL=llama3          # Default model name

# For Ollama running on the host (use from inside containers):
# On Linux:   OLLAMA_BASE_URL=http://host.docker.internal:11434
# On macOS:   OLLAMA_BASE_URL=http://host.docker.internal:11434
# In cluster: OLLAMA_BASE_URL=http://ollama:11434  (with --profile local-llm)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# API keys (only needed for openai/anthropic providers)
# LLM_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-...

# ── Dashboard (Next.js) ────────────────────────────────────
DASHBOARD_PORT=3001       # Host port mapped to dashboard container

# ── Ollama (optional, use --profile local-llm) ─────────────
OLLAMA_PORT=11434         # Host port for Ollama service
