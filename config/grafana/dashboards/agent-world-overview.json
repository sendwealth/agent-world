          "legendFormat": "{{instance }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Agent LLM Tokens Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "rate(agent_llm_tokens_used_total[5m])",
          "legendFormat": "{{ instance }}",
          "refId": "A"
        }
      ]
