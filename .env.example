# ── Agent World Environment Variables ────────────────────────
# Copy this file to .env and adjust values as needed.
# All values have sensible defaults — only override what you need.

# ── World Engine (Rust) ─────────────────────────────────────
ENGINE_PORT=8080          # REST API port
GRPC_PORT=50051           # gRPC A2A protocol port
RUST_LOG=info             # Logging level: trace|debug|info|warn|error

# ── Authentication (REQUIRED) ──────────────────────────────
# JWT_SECRET must be set to a strong random string.
# Generate one: openssl rand -base64 48
JWT_SECRET=change-me-to-a-strong-random-string

# ── Agent Runtime (Python) ──────────────────────────────────
WORLD_ENGINE_URL=http://world-engine:8080
AGENT_COUNT=2

# ── LLM Configuration ───────────────────────────────────────
# Default: Ollama (zero-cost, local). Requires Ollama running with a model pulled.
# Individual agents load their config from config/agents/*.toml
# Alternatives: openai, anthropic, zhipu (智谱GLM-5)
LLM_PROVIDER=ollama
LLM_MODEL=llama3

# --- Ollama (default, zero-cost) ---
# Requires Ollama installed and running (https://ollama.com)
# Pull a model: ollama pull llama3
# Requires ~8GB RAM for llama3
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Zhipu GLM-5 (cheap pay-per-use) ---
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-5
# ZHIPU_API_KEY=your_zhipu_api_key_here
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- OpenAI ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.openai.com/v1

# --- Anthropic ---
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3.5-haiku
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Dashboard (Next.js) ────────────────────────────────────
DASHBOARD_PORT=3001       # Host port mapped to dashboard container

# ── Ollama (optional, use --profile local-llm) ─────────────
OLLAMA_PORT=11434         # Host port for Ollama service
